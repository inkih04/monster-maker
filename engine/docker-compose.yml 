version: '3.8'

services:
  game-runtime:
    build:
      context: .
      dockerfile: Dockerfile
      target: runtime
    image: pokemon-engine:latest
    container_name: pokemon-engine-runtime

    deploy:
      resources:
        limits:
          cpus: '2'
          memory: 2G
        reservations:
          cpus: '1'
          memory: 512M

    environment:
      - DISPLAY=${DISPLAY:-:0}
      - LOG_LEVEL=info

    volumes:
      - ./game_data:/home/gamerunner/game/data
      - ./logs:/home/gamerunner/game/logs

    volumes:
      - /tmp/.X11-unix:/tmp/.X11-unix:ro

    network_mode: host

    restart: unless-stopped


  game-dev:
    build:
      context: .
      dockerfile: Dockerfile
      target: development
    image: pokemon-engine:dev
    container_name: pokemon-engine-dev


    volumes:
      - .:/home/builder/engine
      - build-cache:/home/builder/engine/build


    stdin_open: true
    tty: true


    command: /bin/bash

    working_dir: /home/builder/engine


  builder:
    build:
      context: .
      dockerfile: Dockerfile
      target: builder
    image: pokemon-engine:builder
    container_name: pokemon-engine-builder

    volumes:
      - .:/home/builder/engine
      - build-output:/home/builder/engine/build

    command: >
      bash -c "
        cmake -B build -G Ninja -DCMAKE_BUILD_TYPE=Release &&
        cmake --build build --parallel $(nproc) &&
        test -f build/PokemonGameEngine
      "

volumes:
  build-cache:
  build-output: