###############################################
### ENGINE C++ / CMAKE
###############################################

# CMake build artifacts
CMakeCache.txt
cmake-build-*/
build/
build_*/
build-*/
_build/
CMakeFiles/
CTestTestfile.cmake
cmake_install.cmake
Makefile
CPackConfig.cmake
CPackSourceConfig.cmake

# Auto subprojects generados por CMake
engine/_deps/

# Binarios y librerías compiladas
*.o
*.obj
*.a
*.so
*.so.*
*.dll
*.lib
*.dylib
*.pdb
*.exe
*.out

# Test binaries
engine/test/bin/
engine/test/output/


###############################################
### ENGINE EXTERNAL (SE MANTIENE EL CÓDIGO)
### Ignoramos SOLO lo que genera la compilación
###############################################

# Asegurar que external sí se sube
!engine/external/
!engine/external/**/

# Ignorar builds dentro de external
engine/external/*/build/
engine/external/*/bin/
engine/external/*/lib/
engine/external/*/obj/
engine/external/*/CMakeFiles/
engine/external/*/CMakeCache.txt
engine/external/*/cmake_install.cmake
engine/external/*/Makefile


